---
interface Props {
  title: string;
  slug: string;
  category: string;
  excerpt: string;
  publishDate: Date;
}

const { title, slug, category, excerpt, publishDate } = Astro.props;
const formattedDate = publishDate.toLocaleDateString('en-IN', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="article-card">
  <p class="article-card__category">{category}</p>
  <h3 class="article-card__title">
    <a href={`/insights/${slug}`}>{title}</a>
  </h3>
  <time class="article-card__date" datetime={publishDate.toISOString()}>{formattedDate}</time>
  <p class="article-card__excerpt">{excerpt}</p>
  <a href={`/insights/${slug}`} class="text-link article-card__link">Read more →</a>
</article>

<style>
  .article-card {
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-card);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .article-card__category {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .article-card__title {
    font-size: var(--text-h3);
    line-height: 1.35;
    margin-top: 0.875rem;
  }

  .article-card__title a {
    color: inherit;
  }

  .article-card__title a:hover,
  .article-card__title a:focus-visible {
    color: var(--color-gold-deep);
  }

  .article-card__date {
    font-size: var(--text-caption);
    color: var(--color-muted);
    margin-top: 0.75rem;
  }

  .article-card__excerpt {
    font-size: 0.9375rem;
    line-height: var(--leading-body);
    color: var(--color-body);
    margin-top: 0.75rem;
    flex: 1;
  }

  .article-card__link {
    margin-top: var(--space-3);
    font-size: 0.875rem;
  }
</style>
