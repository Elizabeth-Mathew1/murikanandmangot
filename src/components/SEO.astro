---
interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogImage?: string;
  schema?: Record<string, unknown>;
  preloadHero?: boolean;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage = '/images/og-image.jpg',
  schema,
  preloadHero = false,
} = Astro.props;

const fullTitle = `${title} | Murikan & Mangot`;
const absoluteOgImage = new URL(ogImage, Astro.site).href;
const schemaJson = JSON.stringify(schema ?? {});
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={absoluteOgImage} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content="website" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteOgImage} />
{schema && <script type="application/ld+json" set:html={schemaJson} />}
{preloadHero && (
  <>
    <link rel="preload" as="image" href="/images/hero/hero-1200.webp" type="image/webp" />
    <link rel="preload" as="image" href="/images/hero/hero-1200.jpg" type="image/jpeg" />
  </>
)}
