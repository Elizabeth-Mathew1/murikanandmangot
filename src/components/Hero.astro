---
interface Props {
  image: string;
  imageAlt: string;
  eyebrow: string;
  headline: string;
  subtext: string;
  cta1Label: string;
  cta1Href: string;
  cta2Label?: string;
  cta2Href?: string;
}

const {
  image,
  imageAlt,
  eyebrow,
  headline,
  subtext,
  cta1Label,
  cta1Href,
  cta2Label,
  cta2Href,
} = Astro.props;

const base = image.replace(/\.[^.]+$/, '');
---

<section class="hero" aria-label="Introduction">
  <picture class="hero__media">
    <source
      type="image/webp"
      srcset={`${base}-800.webp 800w, ${base}-1200.webp 1200w, ${base}-1920.webp 1920w`}
      sizes="100vw"
    />
    <img
      src={`${base}-1200.jpg`}
      srcset={`${base}-800.jpg 800w, ${base}-1200.jpg 1200w, ${base}-1920.jpg 1920w`}
      sizes="100vw"
      alt={imageAlt}
      width="1920"
      height="1080"
      fetchpriority="high"
      decoding="async"
    />
  </picture>
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="hero__content container">
    <p class="hero__eyebrow eyebrow eyebrow--dark">{eyebrow}</p>
    <h1 class="hero__headline" set:html={headline} />
    <p class="hero__subtext">{subtext}</p>
    <div class="btn-group hero__ctas">
      <a href={cta1Href} class="btn btn--primary">{cta1Label}</a>
      {cta2Label && cta2Href && (
        <a href={cta2Href} class="btn btn--secondary-dark">{cta2Label}</a>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: stretch;
    overflow: hidden;
    margin-top: calc(-1 * var(--nav-height));
  }

  .hero__media,
  .hero__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      color-mix(in srgb, var(--color-hero-overlay) 80%, transparent) 0%,
      color-mix(in srgb, var(--color-hero-overlay) 58%, transparent) 50%,
      color-mix(in srgb, var(--color-hero-overlay) 20%, transparent) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    width: 100%;
    padding-top: calc(var(--nav-height) + var(--space-4));
    padding-bottom: var(--space-8);
    max-width: 45rem;
  }

  .hero__headline {
    font-size: var(--text-hero);
    line-height: var(--leading-hero);
    color: #fff;
    margin-top: var(--space-3);
    max-width: 45rem;
  }

  .hero__subtext {
    font-size: clamp(0.9375rem, 2vw, 1.0625rem);
    line-height: var(--leading-body);
    color: var(--color-text-on-dark);
    margin-top: var(--space-3);
    max-width: 33.75rem;
  }

  .hero__ctas {
    margin-top: var(--space-4);
  }

  @media (max-width: 767px) {
    .hero {
      min-height: 100vh;
      min-height: 100dvh;
      margin-top: calc(-1 * var(--nav-height-mobile));
    }

    .hero__overlay {
      background: linear-gradient(
        to top,
        color-mix(in srgb, var(--color-hero-overlay) 85%, transparent) 0%,
        color-mix(in srgb, var(--color-hero-overlay) 50%, transparent) 50%,
        color-mix(in srgb, var(--color-hero-overlay) 30%, transparent) 100%
      );
    }

    .hero__content {
      justify-content: flex-end;
      padding-top: calc(var(--nav-height-mobile) + var(--space-4));
      padding-bottom: var(--space-6);
    }

    .hero__eyebrow {
      font-size: 0.6875rem;
    }
  }
</style>
