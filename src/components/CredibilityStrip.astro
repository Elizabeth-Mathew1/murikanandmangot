---
const items = [
  {
    label: 'Practising before the High Court of Kerala',
    icon: 'court',
  },
  {
    label: 'Established in Ernakulam',
    icon: 'calendar',
  },
  {
    label: 'Ernakulam, Kochi, Kerala',
    icon: 'location',
  },
];
---

<section class="credibility" aria-label="Credentials">
  <ul class="credibility__list container">
    {items.map((item, index) => (
      <>
        {index > 0 && <li class="credibility__divider" aria-hidden="true"></li>}
        <li class="credibility__item">
          <span class="credibility__icon" aria-hidden="true">
            {item.icon === 'court' && (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 21h18M4 18h16M6 18V9l6-5 6 5v9M9 21v-4h6v4" />
              </svg>
            )}
            {item.icon === 'calendar' && (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="5" width="18" height="16" rx="1" />
                <path d="M8 3v4M16 3v4M3 10h18" />
              </svg>
            )}
            {item.icon === 'location' && (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11z" />
                <circle cx="12" cy="10" r="2.5" />
              </svg>
            )}
          </span>
          <span class="credibility__text">{item.label}</span>
        </li>
      </>
    ))}
  </ul>
</section>

<style>
  .credibility {
    background-color: var(--color-ink);
    padding-block: var(--space-3);
  }

  .credibility__list {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
    padding-block: var(--space-1);
  }

  @media (min-width: 768px) {
    .credibility__list {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: var(--space-6);
    }
  }

  .credibility__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .credibility__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border: 1.5px solid var(--color-gold-light);
    border-radius: 50%;
    color: var(--color-gold-light);
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .credibility__icon {
      width: 2rem;
      height: 2rem;
    }
  }

  .credibility__text {
    font-size: clamp(0.75rem, 2vw, 0.8125rem);
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-on-dark);
  }

  .credibility__divider {
    width: 100%;
    height: 1px;
    background-color: var(--color-gold-hairline);
    opacity: 0.15;
    list-style: none;
  }

  @media (min-width: 768px) {
    .credibility__divider {
      width: 1px;
      height: 2rem;
      opacity: 0.25;
    }
  }
</style>
