---
interface Props {
  headline?: string;
  subtext?: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const {
  headline = 'Have a legal question?',
  subtext = 'We are available for a conversation at your convenience.',
  buttonLabel = 'Get in Touch',
  buttonHref = '/contact',
} = Astro.props;
---

<section class="cta-band" aria-label="Contact call to action">
  <div class="cta-band__inner container">
    <h2 class="cta-band__headline">{headline}</h2>
    <p class="cta-band__subtext">{subtext}</p>
    <a href={buttonHref} class="btn btn--primary cta-band__btn">{buttonLabel}</a>
  </div>
</section>

<style>
  .cta-band {
    background-color: var(--color-ink);
    padding-block: clamp(3rem, 6vw, 4rem);
    text-align: center;
  }

  .cta-band__headline {
    font-size: var(--text-h2);
    color: var(--color-ivory);
  }

  .cta-band__subtext {
    font-size: var(--text-body);
    color: var(--color-muted-on-dark);
    margin-top: 0.875rem;
    max-width: 32rem;
    margin-inline: auto;
  }

  .cta-band__btn {
    margin-top: var(--space-4);
  }
</style>
