---
import SEO from '../components/SEO.astro';
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogImage?: string;
  schema?: Record<string, unknown>;
  preloadHero?: boolean;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/eb-garamond-v27-latin-500.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/montserrat-v26-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <SEO {...props} />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
